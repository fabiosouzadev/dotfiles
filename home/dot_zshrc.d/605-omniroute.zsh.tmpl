## ═══════════════════════════════════════════════════════════════════════════════
## OmniRoute — Aliases de gerenciamento
## ═══════════════════════════════════════════════════════════════════════════════

## Aliases universais (funcionam em qualquer OS)
alias -- omniroute-health="curl -sf http://localhost:20128/health 2>/dev/null && echo ' ✓ OmniRoute healthy' || echo ' ✗ OmniRoute not running'"
alias -- omniroute-dashboard="open http://localhost:20128 2>/dev/null || xdg-open http://localhost:20128 2>/dev/null || echo 'Dashboard: http://localhost:20128'"
alias -- omniroute-models="curl -sf http://localhost:20128/v1/models -H 'Authorization: Bearer ' 2>/dev/null | jq '.data[].id' 2>/dev/null || echo 'OmniRoute not running or no models available'"

## Update: instala versão específica via npm
## Uso: omniroute-update        → versão mais nova (latest)
##      omniroute-update 3.8.35 → versão específica
omniroute-update() {
  local version="${1:-latest}"
  echo "==> Atualizando OmniRoute para $version..."
  npm install -g omniroute@"$version"
  echo "✓ OmniRoute $(omniroute --version 2>/dev/null | tail -1) instalado"
}

## Alias de sincronização via Chezmoi
alias -- omniroute-sync-push="omniroute-sync push"
alias -- omniroute-sync-pull="omniroute-sync pull"
alias -- omniroute-sync-status="omniroute-sync status"
alias -- omniroute-sync-doctor="omniroute-sync doctor"

