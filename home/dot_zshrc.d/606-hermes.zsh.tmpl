# Hermes Agent CLI
# Aliases para comandos Hermes
alias hermes-sync='hermes-sync-push'

# Aliases para OmniRoute
alias omniroute-restart='systemctl --user restart omniroute'
alias omniroute-health='curl -s http://localhost:20128/status'

# Aliases para chezmoi
alias chezmoi-cd='chezmoi cd'
alias chezmoi-apply='chezmoi apply'

# Aliases para SSH
alias vps='ssh vps'
alias vps-status='ssh vps -- systemctl status omniroute'