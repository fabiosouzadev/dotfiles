{{- if .openclaw.install }}
{{ template "common/script_eval_mise" . }}

fpath=("$HOME/.local/share/zsh/site-functions" $fpath)

OPENCLAW_COMPLETION="$HOME/.local/share/zsh/site-functions/openclaw.zsh"

if [ -f $OPENCLAW_COMPLETION ]; then
	zinit ice as"completion"
	zinit snippet $OPENCLAW_COMPLETION
fi

{{- end }}
