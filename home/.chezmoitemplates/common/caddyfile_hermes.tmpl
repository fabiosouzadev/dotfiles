{{- define "caddyfile/hermes" -}}
{{- if and .settings.vps (ne .features.ai.hermes.dashboard.domain "") }}
{{ .features.ai.hermes.dashboard.domain }} {
    # Reverse proxy para o Hermes Dashboard
    handle_path /hermes* {
        reverse_proxy 127.0.0.1:{{ .features.ai.hermes.dashboard.port }} {
            header_up X-Forwarded-Prefix "/hermes"
        }
    }

    # Health check endpoint (sem path prefix)
    handle /healthz {
        reverse_proxy 127.0.0.1:{{ .features.ai.hermes.dashboard.port }}
    }

    log {
        output file /var/log/caddy/hermes-access.log
        format console
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # WebSocket support para dashboard em tempo real
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websocket 127.0.0.1:{{ .features.ai.hermes.dashboard.port }}
}
{{- end -}}
{{- end -}}