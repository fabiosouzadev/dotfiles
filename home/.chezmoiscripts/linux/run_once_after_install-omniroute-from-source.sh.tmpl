#!/usr/bin/env bash
# OmniRoute installation script for chezmoi (run_once_after)
# Installs/Updates OmniRoute from source with health checks and logging.
# This script is idempotent and safe to re-run.

set -euo pipefail

# --- Configuração ---
OMNIROUTE_REPO="https://github.com/diegosouzapw/OmniRoute.git"
OMNIROUTE_DIR={{ .chezmoi.homeDir }}/.local/src/OmniRoute
OMNIROUTE_ENV_DIR={{ .chezmoi.homeDir }}/.omniroute
OMNIROUTE_VERSION="{{ .omniroute.install.version }}"

# --- Normalizar versão ---
# Adicionar prefixo 'v' se for versão semântica no formato numérique (ex: 3.8.35 → v3.8.35)
if [[ "$OMNIROUTE_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "🔧 Normalizando versão: '$OMNIROUTE_VERSION' → 'v$OMNIROUTE_VERSION'"
    OMNIROUTE_VERSION="v$OMNIROUTE_VERSION"
fi
LOG_FILE="/tmp/chezmoi/logs/omniroute-install-$(date +%Y%m%d_%H%M%S).log"
MAX_RETRIES=5
RETRY_DELAY=5

# --- Logging ---
mkdir -p "$(dirname "$LOG_FILE")"
exec > >(tee -a "$LOG_FILE") 2>&1
echo "🚀 OmniRoute Installation Log - $(date)"
echo "----------------------------------------"

# --- Funções Auxiliares ---
function health_check() {
    local retries=0
    while (( retries < MAX_RETRIES )); do
        if curl -sSf "$HEALTH_CHECK_URL" >/dev/null 2>&1; then
            echo "✅ OmniRoute is healthy and responding."
            return 0
        else
            retries=$((retries + 1))
            echo "⚠️  Health check failed (attempt $retries/$MAX_RETRIES). Retrying in $RETRY_DELAY seconds..."
            sleep "$RETRY_DELAY"
        fi
    done
    echo "❌ OmniRoute health check failed after $MAX_RETRIES attempts."
    return 1
}

function ensure_env_file() {
    if [[ ! -d "$OMNIROUTE_ENV_DIR" ]]; then
        echo "📝 Creating OmniRoute config directory..."
        mkdir -p "$OMNIROUTE_ENV_DIR"
    fi
}

function read_env_port() {
    local env_file="$1"
    local port=20128  # default
    if [[ -f "$env_file" ]]; then
        # Extract PORT value, ignoring comments and whitespace
        port=$(grep -E '^[[:space:]]*PORT[[:space:]]*=' "$env_file" | sed -E 's/^[[:space:]]*PORT[[:space:]]*=[[:space:]]*([^[:space:]]*).*$/\1/' | tr -d '"' | tr -d "'")
        # If port is empty or not a number, use default
        if [[ -z "$port" ]] || ! [[ "$port" =~ ^[0-9]+$ ]]; then
            port=20128
            echo "⚠️  Invalid or missing PORT in $env_file. Using default: $port"
        fi
    else
        echo "⚠️  $env_file not found. Using default PORT: $port"
    fi
    echo "$port"
}

# --- Instalação/Atualização ---
echo "📁 Ensuring OmniRoute directory exists..."
mkdir -p "$(dirname "$OMNIROUTE_DIR")"

echo "🔍 Checking OmniRoute repository..."
if [[ -d "$OMNIROUTE_DIR" ]]; then
    echo "📁 OmniRoute directory found. Deleting..."
    rm -rf "$OMNIROUTE_DIR"
fi

echo "📥 Cloning OmniRoute repository..."
git clone "$OMNIROUTE_REPO" "$OMNIROUTE_DIR"
cd "$OMNIROUTE_DIR"
git fetch --tags origin
if [[ "$OMNIROUTE_VERSION" == "latest" ]]; then
    echo "🔖 Checking out latest version (main branch)..."
    git checkout main
else
    if git show-ref --tags --quiet --verify -- "refs/tags/$OMNIROUTE_VERSION"; then
        echo "🔖 Checking out version $OMNIROUTE_VERSION..."
        git checkout "$OMNIROUTE_VERSION"
    else
        echo "❌ Tag $OMNIROUTE_VERSION not found. Falling back to main."
        git checkout main
    fi
fi

echo "📦 Ensuring Node.js LTS is installed via mise..."
if command -v mise &> /dev/null; then
 mise install node@lts
 mise use node@lts
else
    echo "❌ mise not found. Please install mise or ensure Node.js LTS is available."
    exit 1
fi

echo "📦 Installing Node.js dependencies..."
npm ci

echo "🔨 Building OmniRoute CLI..."
npm run build:release

# --- Configuração do Serviço ---
ensure_env_file

# Read PORT from .env file for health check
OMNIROUTE_PORT=$(read_env_port "$OMNIROUTE_ENV_DIR/.env")
HEALTH_CHECK_URL="http://localhost:${OMNIROUTE_PORT}/api/monitoring/health"
echo "🔍 Health check will target: $HEALTH_CHECK_URL"

echo "📋 Refreshing systemd..."
systemctl --user daemon-reload
systemctl --user enable omniroute.service

echo "🔄 Restarting OmniRoute service..."
systemctl --user restart omniroute.service

# --- Verificação ---
echo "🏥 Performing health check..."
if health_check; then
    echo "✅ OmniRoute installation/update completed successfully!"
    echo "📊 Dashboard: http://localhost:${OMNIROUTE_PORT}"
    echo "🔌 API Base: http://localhost:${OMNIROUTE_PORT}/v1  # Assuming API is PORT+1"
else
    echo "❌ OmniRoute installation/update failed. Check logs at $LOG_FILE"
    exit 1
fi