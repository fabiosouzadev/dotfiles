#!/usr/bin/env bash

set -euo pipefail

{{ template "workplace/script_is_not_zup" . }}
{{ template "common/script_is_not_ephemeral" . }}
{{ template "linux/script_linux_only" . }}
{{ template "common/script_helper" . }}

{{ if .settings.vps }}
info ">> Tmux: VPS detected, skipping Tmux build <<"
exit 0
{{ end }}

{{- if .settings.ismanaged }}

info ">>> Install Tmux from release <<<<"

cd /tmp

# Detect architecture
ARCH="$(uname -m)"
case "$ARCH" in
    x86_64)  TMUX_ARCH="x86_64" ;;
    aarch64) TMUX_ARCH="aarch64" ;;
    arm64)   TMUX_ARCH="aarch64" ;;
    *)
        error "Unsupported architecture: $ARCH"
        exit 1
        ;;
esac

# Get latest release version from GitHub API
info "Fetching latest tmux release..."
TMUX_VERSION=$(curl -fsSL "https://api.github.com/repos/tmux/tmux/releases/latest" \
    | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/')

if [ -z "$TMUX_VERSION" ]; then
    error "Could not determine latest tmux version"
    exit 1
fi

info "Installing tmux ${TMUX_VERSION} for linux-${TMUX_ARCH}..."

TMUX_FILE="tmux-${TMUX_VERSION}-linux-${TMUX_ARCH}.tar.gz"
TMUX_URL="https://github.com/tmux/tmux/releases/download/${TMUX_VERSION}/${TMUX_FILE}"

if ! curl -fsSL "$TMUX_URL" -o "$TMUX_FILE"; then
    error "Failed to download $TMUX_URL"
    exit 1
fi

tar xzf "$TMUX_FILE"
cp -fr "tmux-${TMUX_VERSION}-linux-${TMUX_ARCH}"/* ~/.local

{{- else if not .settings.ismanaged }}

# ----------------------------
# Ubuntu
# ----------------------------
{{- if .settings.osid | lower | contains "ubuntu" }}

info ">>> Install dependencies Tmux (Ubuntu)"

sudo apt install -y \
  libevent-dev \
  ncurses-dev \
  build-essential \
  bison \
  pkg-config

{{- end }}

# ----------------------------
# Arch / EndeavourOS / CachyOS
# ----------------------------
{{- if or ( .settings.osid | lower | contains "endeavouros") ( .settings.osid | lower | contains "cachyos") }}

info ">>> Install dependencies Tmux (Arch)"

sudo pacman -Syyu --noconfirm --needed \
    base-devel \
    libevent \
    ncurses \
    make \
    bison \
    pkg-config

{{- end }}

# ----------------------------
# Remove previous Tmux installations
# ----------------------------

info ">>> Remove previous Tmux installations"

if [ -d $HOME/.local/share/tmux/ ]; then 
  sudo rm -r $HOME/.local/share/tmux
fi
if [ -f /usr/local/bin/tmux ]; then
  sudo rm /usr/local/bin/tmux 
fi
if [ -f $HOME/.local/bin/tmux ]; then
  sudo rm $HOME/.local/bin/tmux 
fi
if [ -d $HOME/.local/src/tmux ]; then 
  sudo rm -r $HOME/.local/src/tmux 
fi
if [ -d $HOME/.local/state/nvim ]; then 
  sudo rm -r $HOME/.local/state/nvim 
fi
if [ -d $HOME/.tmux ]; then
  sudo rm -r $HOME/.tmux
fi

# ----------------------------
# Build Tmux from source
# ----------------------------
info ">>> Build Tmux from source"

git clone https://github.com/tmux/tmux.git $HOME/.local/src/tmux
cd $HOME/.local/src/tmux
git pull
#git checkout 3.3a
sh autogen.sh
# Test config (https://github.com/tmux/tmux/issues/3218)
sudo ./configure --enable-debug
sudo make 
sudo make install

{{- end }}

success ">>> Tmux configured successfully"
# vim: filetype=bash
