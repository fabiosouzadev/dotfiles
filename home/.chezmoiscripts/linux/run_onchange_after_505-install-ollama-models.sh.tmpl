#!/usr/bin/env bash
{{ template "common/script_helper" . -}}
{{ template "common/script_is_not_ephemeral" . }}
{{ template "workplace/script_is_not_vps" . }}
{{ if .features.ollama.localmodels.enabled -}}

  info "Installing Ollama models"

  if type ollama >/dev/null 2>&1; then
    info "Installing Ollama models"
    {{ range .features.ollama.models }} 
      info "📥 Ollama pulling {{ . }} ..."
      ollama pull {{.}}
    {{ end }}

  fi

  success "Installed Ollama models"

{{ end -}}
# vim: filetype=bash