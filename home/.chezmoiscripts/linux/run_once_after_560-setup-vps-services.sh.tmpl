#!/usr/bin/env bash
# vim: filetype=bash

set -euo pipefail

{{ template "common/script_is_not_ephemeral" . }}
{{ template "linux/script_linux_only" . }}
{{ template "common/script_helper" . }}

{{ if not .settings.vps }}
info ">> VPS Services: not a VPS profile, skipping <<"
exit 0
{{ end }}

info ">>>>>>> 🚀 Setting up VPS Services 🚀 <<<<<<<"

if ! command -v systemctl &> /dev/null; then
    warn "systemctl not found, skipping service setup."
    exit 0
fi

systemctl --user daemon-reload

{{ if eq .features.ai.omniroute.mode "vps-server" }}
info "Starting OmniRoute Service"
systemctl --user enable --now omniroute.service || true
{{ end }}

{{ if .features.ai.openclaw.gateway }}
info "Starting OpenClaw Gateway Service"
# Note: openclaw gateway creates 'openclaw-gateway.service'
systemctl --user enable --now openclaw-gateway.service || true
{{ end }}

{{ if ne .features.ai.omniroute.domain "" }}
info "Applying Caddy Configuration"
if command -v caddy &> /dev/null; then
    sudo cp "$HOME/.config/caddy/Caddyfile" /etc/caddy/Caddyfile
    sudo systemctl reload caddy || sudo systemctl restart caddy || true
    success "Caddyfile applied."
fi
{{ end }}

success "VPS Services setup completed"
