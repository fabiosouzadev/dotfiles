#!/usr/bin/env bash
# Instala / atualiza o OmniRoute from source
# Uso (via chezmoi apply): instala a versão do omniroute.yaml
# Uso (direto ou via omniroute-update): passa versão como argumento
set -euo pipefail

SRC_DIR="{{ .chezmoi.homeDir }}/.local/src/OmniRoute"
DIST_DIR="$SRC_DIR/dist"
SERVER_JS="$DIST_DIR/server.js"
BIN_LINK="{{ .chezmoi.homeDir }}/.local/bin/omniroute"
VERSION="{{ .omniroute.install.version }}"

# Permite sobrescrever via argumento
if [[ "${1:-}" =~ ^v?[0-9] || "${1:-}" == "main" || "${1:-}" == "master" ]]; then
  VERSION="$1"
fi

echo "==> OmniRoute — instalando from source (versão: $VERSION)"

# 0. Detecta Node.js (prioriza mise > sistema, exige >=20.9)
NPM_CMD="npm"
NODE_CMD="node"
if command -v mise &>/dev/null; then
  MISE_NODE="$(mise which node 2>/dev/null || true)"
  MISE_NPM="$(mise which npm 2>/dev/null || true)"
  if [[ -n "$MISE_NODE" && -x "$MISE_NODE" ]]; then
    NODE_CMD="$MISE_NODE"
    NPM_CMD="${MISE_NPM:-$MISE_NODE/bin/npm}"
    echo "  → Usando Node via mise: $($NODE_CMD --version)"
  fi
fi

NODE_VER=$("$NODE_CMD" --version 2>/dev/null | sed 's/v//')
NODE_MAJOR=$(echo "$NODE_VER" | cut -d. -f1)
if [[ "$NODE_MAJOR" -lt 20 ]]; then
  echo "  ✗ ERRO: Node.js $NODE_VER encontrado, mas OmniRoute precisa >=20.9"
  echo "    Instale o Node 20+ via mise: mise install node@lts"
  exit 1
fi

# 1. Remove versão antiga do npm global (se existir)
echo "  → Removendo versão npm antiga..."
"$NPM_CMD" uninstall -g omniroute 2>/dev/null || true

# 2. Remove binário/shim antigo
rm -f "$BIN_LINK" 2>/dev/null || true

# 3. Garante diretórios
mkdir -p "$(dirname "$BIN_LINK")"

# 4. Clona ou atualiza o repo
if [[ -d "$SRC_DIR/.git" ]]; then
  echo "  → Repo já existe, atualizando..."
  cd "$SRC_DIR"
  git fetch --all --tags --prune 2>&1 | sed 's/^/    /'
else
  echo "  → Clonando {{ .omniroute.install.repo }}..."
  git clone "{{ .omniroute.install.repo }}" "$SRC_DIR" 2>&1 | sed 's/^/    /'
  cd "$SRC_DIR"
fi

# 5. Checkout da versão desejada
if [[ "$VERSION" == "main" || "$VERSION" == "master" ]]; then
  echo "  → Checkout main (versão mais recente)..."
  git checkout main 2>&1 | sed 's/^/    /'
  git pull origin main 2>&1 | sed 's/^/    /'
else
  echo "  → Checkout $VERSION..."
  git checkout "$VERSION" 2>&1 | sed 's/^/    /'
fi

# 6. Build completo: next build + CLI
echo "  → Instalando dependências (node $($NODE_CMD --version))..."
"$NPM_CMD" ci 2>&1 | sed 's/^/    /'

echo "  → Buildando (next build)..."
PATH="$(dirname "$NODE_CMD"):$PATH" "$NPM_CMD" run build 2>&1 | sed 's/^/    /'

echo "  → Buildando CLI..."
PATH="$(dirname "$NODE_CMD"):$PATH" "$NPM_CMD" run build:cli 2>&1 | sed 's/^/    /'

# 7. Verifica que dist/ foi gerado
if [[ ! -f "$SERVER_JS" ]]; then
  echo "  ✗ ERRO: dist/server.js não encontrado após build"
  echo "    Verifique os erros de build acima."
  exit 1
fi

# 8. Cria wrapper script em ~/.local/bin/omniroute
cat > "$BIN_LINK" << 'WRAPPER'
#!/usr/bin/env bash
# OmniRoute wrapper — executa dist/server.js com Node do mise
NODE_CMD="node"
if command -v mise &>/dev/null; then
  MISE_NODE="$(mise which node 2>/dev/null || true)"
  [[ -n "$MISE_NODE" && -x "$MISE_NODE" ]] && NODE_CMD="$MISE_NODE"
fi
exec "$NODE_CMD" "{{ .chezmoi.homeDir }}/.local/src/OmniRoute/dist/server.js" "$@"
WRAPPER
chmod +x "$BIN_LINK"

echo "  → Binário: $BIN_LINK → $SERVER_JS"

# 9. Verificação
INSTALLED_VER=$("$BIN_LINK" --version 2>/dev/null || echo "desconhecida")
echo "✓ OmniRoute instalado com sucesso (dist/ + wrapper)"
