#!/usr/bin/env bash

{{ template "common/script_helper" . -}}
{{- template "linux/script_linux_only" . -}}
{{ template "common/script_is_not_ephemeral" . }}

INSTALL_DIR= {{- .dirs.local }}
LOG_DIR={{ .features.ai.ollama.path.logs }}
SRC_DIR={{ .dirs.src }}
BIN_DIR={{ .dirs.bin }}

{{- if .features.ai.ollama.install }}

info ">>> 🐑 Installing Ollama in mode {{ .features.ai.ollama.mode }}  🐑"

# --------------------------------------------------------------------
# USER MODE (WSL / ambiente gerenciado)
# --------------------------------------------------------------------
{{-  if eq .features.ai.ollama.mode "user" }}

OLLAMA_VERSION="v0.24.0"

rm -rf "$HOME/.ollama"
rm -f "$INSTALL_DIR/bin/ollama"
rm -rf "$INSTALL_DIR/lib/ollama"

# garante zstd local
if ! command -v zstd >/dev/null 2>&1; then
  echo ">>> Installing zstd local"
  curl -L https://github.com/facebook/zstd/releases/latest/download/zstd-linux-amd64 -o "$BIN_DIR/zstd"
  chmod +x "$BIN_DIR/zstd"
  export PATH="$BIN_DIR:$PATH"
fi

mkdir -p "$INSTALL_DIR"
cd "$SRC_DIR"

export PATH="${INSTALL_DIR}/bin:${PATH}"

curl -fL https://github.com/ollama/ollama/releases/download/$OLLAMA_VERSION/ollama-linux-amd64.tar.zst -o ollama-linux-amd64.tar.zst
tar --zstd -xvf ollama-linux-amd64.tar.zst -C "${INSTALL_DIR}"

export PATH="${INSTALL_DIR}/bin:${PATH}"
export LD_LIBRARY_PATH="${INSTALL_DIR}/lib/ollama:${LD_LIBRARY_PATH:-}"

mkdir -p "$LOG_DIR"

if {{ .features.runtime.background_services }}; then
  nohup ollama serve > "$LOG_DIR/server.log" 2>&1 &
  success "Ollama rodando em background"
else
  warn "Background desabilitado — execute manualmente: ollama serve"
fi

success "🐑 Ollama Installed in $INSTALL_DIR version: $(ollama -v) 🐑 "

# --------------------------------------------------------------------
# ROOT MODE
# --------------------------------------------------------------------

{{-  else if eq .features.ai.ollama.mode "root" }}

{{ if .features.systemd.enabled }}
sudo systemctl stop ollama
sudo systemctl disable ollama

if [ -f /etc/systemd/system/ollama.service ]; then
  sudo rm /etc/systemd/system/ollama.service
fi
{{ end }}

info " 🐑 Instalando Ollama 🐑 "
curl -fsSL https://ollama.com/install.sh | sh

{{ if .features.systemd.enabled }}
sudo systemctl daemon-reload
sudo systemctl enable --now ollama
{{ end }}

success "Ollama Installed version: $(ollama -v) 🐑"

{{-  else if eq .features.ai.ollama.mode "compile" }}
# --------------------------------------------------------------------
# COMPILE MODE (opcional avançado)
# --------------------------------------------------------------------

# PATH correto para ambiente não-interativo
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

info ">>> 🐑🔨 Instalando dependências de compilação... 🐑"

{{- if (or (eq .chezmoi.osRelease.id "endeavouros") (eq .chezmoi.osRelease.id "cachyos")) }}

sudo pacman -Syyu --noconfirm --needed base-devel git cmake make gcc clang

{{- end }}

info ">>> 🔨 Compilando Ollama ..."
[ ! -d "$SRC_DIR/ollama-source" ] || rm -rf $SRC_DIR/ollama-source/
git clone https://github.com/ollama/ollama.git $SRC_DIR/ollama-source
cd ~/ollama-source

# COMPILAR OLLAMA COM PATCHES ESPECÍFICOS PARA ALDER LAKE-U
{{- if .settings.dell3530 }}
info ">>> 🐑🔨 Compilando Ollama com otimizações para Alder Lake-U (i7-1355U)"

# Compila com flags específicas para Tiger Lake
info ">>> 🐑🔨 ⚡ Compilando com flags Alder Lake-U (i7-1355U)"
export CGO_CFLAGS="-O3 -march=alderlake -mtune=alderlake -mavx2 -mfma -flto -fno-plt -fassociative-math -freciprocal-math -fno-signed-zeros -fno-trapping-math"
export CGO_LDFLAGS="-O3 -march=alderlake -mtune=alderlake -mavx2 -mfma -flto -fno-plt"
# export CGO_CFLAGS="-O3 -march=alderlake -mtune=alderlake -mavx2 -mfma -fno-plt"
# export CGO_LDFLAGS="-O3 -march=alderlake -mtune=alderlake -mavx2 -mfma"
export CPU_FLAGS="-O3 -march=alderlake -mtune=alderlake -pipe -flto -ffast-math -fomit-frame-pointer"
export CC=clang
export CXX=clang++
export CFLAGS="$CPU_FLAGS"
export CXXFLAGS="$CPU_FLAGS"
export LDFLAGS="-Wl,-O1 -Wl,--as-needed -Wl,-z,now -Wl,-z,relro"
export CGO_ENABLED=1
export OLLAMA_THREADS=10
export OLLAMA_PARALLEL=8
{{- end }} # dell3530

#COMPILAR OLLAMA COM PATCHES ESPECÍFICOS PARA TIGER LAKE
{{- if .settings.dell3520 }}
info ">>> 🐑🔨 Compilando Ollama com otimizações para i5-1135G7..."

# Compila com flags específicas para Tiger Lake
info ">>> ⚡ Compilando com flags AVX2 otimizadas..."
export CGO_CFLAGS="-O3 -march=native -mtune=native -mavx2 -mfma -fno-plt"
export CGO_LDFLAGS="-O3 -march=native -mtune=native -mavx2 -mfma"
export CPU_FLAGS="-O3 -march=tigerlake -mtune=tigerlake -pipe -flto -ffast-math -fomit-frame-pointer"
export CC=clang
export CXX=clang++
export CFLAGS="$CPU_FLAGS"
export CXXFLAGS="$CPU_FLAGS"
export LDFLAGS="-Wl,-O1 -Wl,--as-needed -Wl,-z,now -Wl,-z,relro"
export CGO_ENABLED=1
{{- end }} # dell3520

export GOFLAGS="-buildmode=pie -trimpath -ldflags=-s -ldflags=-w"

#Compilação
INSTALL_DIR="/usr/local/bin"
go clean
go mod tidy
go build \
  -tags "avx avx2" \
  -ldflags="-s -w -extldflags '-static' -X main.version=custom-cachyos" \
  -o ollama .

sudo install -Dm755 ollama "$INSTALL_DIR/ollama"

# Instala a versão compilada
# sudo cp ./bin/ollama /usr/local/bin/
sudo chmod +x /usr/local/bin/ollama

success "🐑🔨Ollama compilado com sucesso! 🐑🔨"

#CONFIGURAR SERVIÇO SYSTEMD OTIMIZADO
{{- if .features.systemd.enabled }}
info "⚙️ Configurando serviço systemd ..."

sudo tee /etc/systemd/system/ollama.service > /dev/null <<'EOF'
[Unit]
Description=Ollama Service
After=network-online.target

[Service]
ExecStart=/usr/local/bin/ollama serve
User=ollama
Group=ollama
Restart=always
RestartSec=3
Environment="PATH=$PATH"

[Install]
WantedBy=multi-user.target
EOF

sudo useradd -r -s /bin/false -U -m -d /usr/share/ollama ollama
sudo usermod -a -G ollama $(whoami)
{{- end }}
{{- end }}

### Override Service
{{- if not (eq .features.ai.ollama.mode "user")}}

[ -d /etc/systemd/system/ollama.service.d ] || sudo mkdir /etc/systemd/system/ollama.service.d/

sudo tee /etc/systemd/system/ollama.service.d/override.conf > /dev/null <<'EOF'
[Service]
{{ range .features.ai.ollama.environments -}}
Environment={{.}}
{{ end -}}

# Prioridade de CPU para evitar travamentos
Nice=-5
CPUSchedulingPolicy=rr
CPUSchedulingPriority=1

# Limites de memória realistas para 16GB
MemoryHigh=12G
MemoryMax=14G
MemorySwapMax=4G

EOF

sudo systemctl daemon-reload
sudo systemctl enable --now ollama.service
success "✨ Seu setup de IA local está 100% otimizado para alto desempenho!"

sleep 3

{{- end }}

{{- end }}