#!/usr/bin/env bash
# vim: filetype=bash
# chezmoi: run_once_after_531-install-agentmemory.sh.tmpl
# Instala agentmemory — persistent memory server for AI coding agents

set -euo pipefail

{{ template "common/script_is_not_ephemeral" . }}
{{ template "linux/script_linux_only" . }}
{{ template "common/script_helper" . }}
{{ template "workplace/script_is_vps" . }}

{{ if not .features.ai.agentmemory.install }}
info ">> Agentmemory: not needed, skipping <<"
exit 0
{{ end }}

if command -v agentmemory &> /dev/null; then
    info "Agentmemory already installed, skipping."
    exit 0
fi

info ">> Installing agentmemory (npm global) <<"
npm install -g @agentmemory/agentmemory

systemctl --user daemon-reload
systemctl --user enable --now agentmemory.service || true

success "Agentmemory installed and service started."
