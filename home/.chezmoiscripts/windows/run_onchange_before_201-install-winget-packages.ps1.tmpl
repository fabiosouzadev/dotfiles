# run_onchange_before_201-install-winget-packages.ps1.tmpl
# Installs Windows packages via winget reading from .chezmoidata/windows/packages.yaml
#
# Hash: {{ .packages.windows.winget | toJson | sha256sum }}

{{ if .packages.windows.winget -}}
$ErrorActionPreference = 'Stop'

function Write-Info  { param($msg) Write-Host "[INFO]    $msg" -ForegroundColor Cyan }
function Write-Ok    { param($msg) Write-Host "[OK]      $msg" -ForegroundColor Green }
function Write-Warn  { param($msg) Write-Host "[WARN]    $msg" -ForegroundColor Yellow }

# Ensure winget is available
if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
    Write-Warn "winget not found. Install App Installer from the Microsoft Store."
    exit 1
}

Write-Info "Updating winget sources..."
winget source update

Write-Info "Installing winget packages..."

{{ range .packages.windows.winget -}}
$pkgId = "{{ . }}"
Write-Info "Processing: $pkgId"

$installed = winget list --id $pkgId --exact --accept-source-agreements 2>$null
if ($LASTEXITCODE -eq 0 -and $installed -match [regex]::Escape($pkgId)) {
    Write-Warn "Already installed: $pkgId"
} else {
    Write-Info "Installing: $pkgId"
    winget install --id $pkgId --exact --accept-package-agreements --accept-source-agreements --silent
    if ($LASTEXITCODE -eq 0) {
        Write-Ok "Installed: $pkgId"
    } else {
        Write-Warn "Failed to install: $pkgId (exit code $LASTEXITCODE)"
    }
}
{{ end }}

Write-Ok "winget packages done."
{{- end }}
