#!/usr/bin/env bash

{{ template "common/script_is_not_ephemeral" . }}


{{ template "common/script_helper" . }}

MISE_INSTALL_PATH="$HOME/.local/bin/mise"

if [ -x "$HOME/.local/bin/mise" ]; then
  mise implode -y
  rm -rf "$MISE_INSTALL_PATH"
  rm -rf "$HOME/.local/share/mise"
  rm -rf "$HOME/.local/state/mise"
{{ if (.settings.osid | lower | contains "linux" ) }}
  rm -rf "$HOME/.cache/mise"
{{ else if  (.settings.osid | lower | contains "darwin" ) }}
  rm -rf ~/Library/Caches/mise
{{ end }}
fi

info ">>> 🧑‍🍳 Installing Mise 🧑‍🍳 <<<"

curl https://mise.run | sh

# PATH correto para ambiente não-interativo
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

{{ template "common/script_validate_completions_path" . }}

"$HOME/.local/bin/mise" completion zsh \
  > "$HOME/.local/share/zsh/site-functions/_mise"

# This requires bash-completion to be installed
"$HOME/.local/bin/mise" completion bash \
  --include-bash-completion-lib > ~/.local/share/bash-completion/completions/mise


{{ if and (.settings.osid | lower | contains "linux" ) (.features.sudo.enabled) }}
# Node.js requires libatomic on Linux
if ! dpkg -l | grep -q "^ii  libatomic1 "; then
    info ">>> Installing libatomic1 (dependency for Node.js)..."
    sudo apt update -y
    sudo apt install -y libatomic1
fi
{{ end }}

info "🧑‍🍳Installing tool versions via mise 🧑‍🍳"
mise install -y

mise activate

info "Running mise doctor"
mise doctor

success "🧑‍🍳 Mise installation completed 🧑‍🍳"
success " 🧑‍🍳 Mise version: $(mise --version) 🧑‍🍳"

# vim: filetype=bash


