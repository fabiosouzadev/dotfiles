{{ if .features.ai.coding_assistants -}}
#!/usr/bin/env bash

{{ template "common/script_is_not_ephemeral" . }}
{{ template "common/script_eval_mise" . }}
{{ template "common/script_helper" . }}
{{ template "workplace/script_is_not_vps" . }}

{{- if or ( .settings.osid | lower | contains "endeavouros" ) ( .settings.osid | lower | contains "cachyos" ) }}

sudo pacman -Syyu --noconfirm --needed gnome-keyring libsecret


{{- else if.settings.osid | lower | contains "ubuntu" }}

sudo apt update && sudo apt install gnome-keyring libsecret-1-0 libsecret-tools

{{- end }}

#Install CodeRabbit CLI
info ">>>>> Installing CodeRabbit CLI"

curl -fsSL https://cli.coderabbit.ai/install.sh | sh

success ">>> CodeRabbit Cli Installed Version: $(coderabbit -V)"

{{- end }}

