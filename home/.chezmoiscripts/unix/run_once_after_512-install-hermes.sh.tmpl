#!/usr/bin/env bash

{{ template "common/script_is_not_ephemeral" . }}
{{ template "common/script_helper" . }}

{{- /* Check if Hermes is enabled */ -}}
{{- $hermesEnabled := false -}}
{{- if hasKey .features.ai "hermes" -}}
  {{- if eq .features.ai.hermes.install true -}}
    {{- $hermesEnabled = true -}}
  {{- end -}}
{{- end -}}

{{ if not $hermesEnabled }}
info ">> Hermes Agent: feature flag disabled, skipping <"
exit 0
{{ end }}

info ">>>>>>> 🏛️ Installing Hermes Agent 🏛️ <<<<<<<"

# Check if Hermes is already installed (idempotency)
if command -v hermes &> /dev/null; then
  info "Hermes is already installed, checking for updates..."
  hermes --version || true
  exit 0
fi

if test -f "$HOME/.hermes/hermes" || test -f "$HOME/.local/bin/hermes"; then
  info "Hermes installation detected, skipping install"
  exit 0
fi

# Install Hermes using official installer
info "Downloading and installing Hermes Agent..."
curl -fsSL https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh | bash

# Verify installation
if command -v hermes &> /dev/null; then
  success ">>> ✅ Hermes Agent installed successfully <<<"
  hermes --version
else
  error ">>> ❌ Hermes installation failed <<<"
  exit 1
fi

# vim: filetype=bash
