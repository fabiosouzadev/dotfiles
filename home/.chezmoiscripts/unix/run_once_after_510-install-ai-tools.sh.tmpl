#!/usr/bin/env bash

{{ template "common/script_is_not_ephemeral" . }}
{{ template "common/script_eval_mise" . }}
{{ template "common/script_helper" . }}

info ">>>>>> 🤖 Installing AI Tools 🤖 <<<<<<<"

{{- /* Install NPM tools */ -}}
{{ range .ai_tools.npm }}
{{- $featureEnabled := false -}}
{{- if eq .feature_flag "coding_assistants" }}{{ $featureEnabled = $.features.ai.coding_assistants }}{{- end -}}
{{- if eq .feature_flag "spec_tools" }}{{ $featureEnabled = $.features.ai.spec_tools }}{{- end -}}

{{ if $featureEnabled }}
info "Installing {{ .name }} (NPM)"
{{ if hasKey . "env" }}{{ .env }} {{ end }}npm install -g {{ .package }}

{{- if hasKey . "completions_cmd" }}
{{ template "common/script_validate_completions_path" $ }}
{{ .completions_cmd }} > "$HOME/.local/share/zsh/site-functions/_{{ .name }}"
{{- end }}
{{- end }}
{{- end }}

{{- /* Install CURL tools */ -}}
{{ range .ai_tools.curl }}
{{- $featureEnabled := false -}}
{{- if eq .feature_flag "coding_assistants" }}{{ $featureEnabled = $.features.ai.coding_assistants }}{{- end -}}
{{- if eq .feature_flag "spec_tools" }}{{ $featureEnabled = $.features.ai.spec_tools }}{{- end -}}

{{ if $featureEnabled }}
info "Installing {{ .name }} (Curl)"
{{ if hasKey . "env" }}{{ .env }} {{ end }}curl -fsSL {{ .url }} | {{ .shell }}
{{- end }}

{{- end }}

success ">>> 🤖 AI Tools Installed 🤖"

# vim: filetype=bash
