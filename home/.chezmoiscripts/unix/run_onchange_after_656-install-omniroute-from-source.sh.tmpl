#!/usr/bin/env bash
# OmniRoute installation script for chezmoi (run_once_after)
# Installs/Updates OmniRoute from source with health checks and logging.
# This script is idempotent and safe to re-run.

{{ template "common/script_helper" . -}}
{{ template "common/script_is_not_ephemeral" . -}}
{{ template "workplace/script_is_vps" . }}

{{ if .features.ai.omniroute.install }}

# --- Configuração ---
OMNIROUTE_REPO="https://github.com/diegosouzapw/OmniRoute.git"
OMNIROUTE_DIR={{ .chezmoi.homeDir }}/.local/src/OmniRoute
OMNIROUTE_ENV_DIR={{ .chezmoi.homeDir }}/.omniroute
OMNIROUTE_VERSION="{{ .omniroute.install.version }}"

# --- Normalizar versão ---
# Adicionar prefixo 'v' se for versão semântica no formato numérique (ex: 3.8.35 → v3.8.35)
if [[ "$OMNIROUTE_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    info "🔧 Normalizando versão: '$OMNIROUTE_VERSION' → 'v$OMNIROUTE_VERSION'"
    OMNIROUTE_VERSION="v$OMNIROUTE_VERSION"
fi
LOG_FILE="/tmp/chezmoi/logs/omniroute-install-$(date +%Y%m%d_%H%M%S).log"
MAX_RETRIES=5
RETRY_DELAY=5

# --- Logging ---
mkdir -p "$(dirname "$LOG_FILE")"
exec > >(tee -a "$LOG_FILE") 2>&1
info "🚀 OmniRoute Installation Log - $(date)"
info "----------------------------------------"

# --- Funções Auxiliares ---
function health_check() {
    local retries=0
    while (( retries < MAX_RETRIES )); do
        if curl -sSf "$HEALTH_CHECK_URL" >/dev/null 2>&1; then
            success "OmniRoute is healthy and responding."
            return 0
        else
            retries=$((retries + 1))
            info "⚠️  Health check failed (attempt $retries/$MAX_RETRIES). Retrying in $RETRY_DELAY seconds..."
            sleep "$RETRY_DELAY"
        fi
    done
    info "❌ OmniRoute health check failed after $MAX_RETRIES attempts."
    return 1
}

function ensure_env_file() {
    if [[ ! -d "$OMNIROUTE_ENV_DIR" ]]; then
        info "📝 Creating OmniRoute config directory..."
        mkdir -p "$OMNIROUTE_ENV_DIR"
    fi
}

function read_env_port() {
    local env_file="$1"
    local port=20128  # default
    if [[ -f "$env_file" ]]; then
        # Extract PORT value, ignoring comments and whitespace
        port=$(grep -E '^[[:space:]]*PORT[[:space:]]*=' "$env_file" | sed -E 's/^[[:space:]]*PORT[[:space:]]*=[[:space:]]*([^[:space:]]*).*$/\1/' | tr -d '"' | tr -d "'")
        # If port is empty or not a number, use default
        if [[ -z "$port" ]] || ! [[ "$port" =~ ^[0-9]+$ ]]; then
            port=20128
            info "⚠️  Invalid or missing PORT in $env_file. Using default: $port"
        fi
    else
        info "⚠️  $env_file not found. Using default PORT: $port"
    fi
    info "$port"
}

# --- Instalação/Atualização ---
info "📁 Ensuring OmniRoute directory exists..."
mkdir -p "$(dirname "$OMNIROUTE_DIR")"

info "🔍 Checking OmniRoute repository..."
if [[ -d "$OMNIROUTE_DIR" ]]; then
    info "📁 OmniRoute directory found. Updating..."
    cd "$OMNIROUTE_DIR"
    if ! git diff --quiet; then
        warn "⚠️  Uncommitted changes detected. Stashing changes..."
        git stash
    fi
    git fetch origin
    git fetch --tags origin
    if [[ "$OMNIROUTE_VERSION" == "latest" ]]; then
        info "🔖 Checking out latest version (main branch)..."
        git reset --hard origin/main
    else
        info "🔖 Checking out version $OMNIROUTE_VERSION..."
        # Check if the tag exists
        if git show-ref --tags --quiet --verify -- "refs/tags/$OMNIROUTE_VERSION"; then
            git reset --hard "$OMNIROUTE_VERSION"
        else
            error "Tag $OMNIROUTE_VERSION not found. Falling back to main."
            git reset --hard origin/main
        fi
    fi
else
    info "📥 Cloning OmniRoute repository..."
    git clone "$OMNIROUTE_REPO" "$OMNIROUTE_DIR"
    cd "$OMNIROUTE_DIR"
    git fetch --tags origin
    if [[ "$OMNIROUTE_VERSION" == "latest" ]]; then
        info "🔖 Checking out latest version (main branch)..."
        git checkout main
    else
        if git show-ref --tags --quiet --verify -- "refs/tags/$OMNIROUTE_VERSION"; then
            info "🔖 Checking out version $OMNIROUTE_VERSION..."
            git checkout "$OMNIROUTE_VERSION"
        else
            error "❌ Tag $OMNIROUTE_VERSION not found. Falling back to main."
            git checkout main
        fi
    fi
fi

info "📦 Ensuring Node.js LTS is installed via mise..."
if command -v mise &> /dev/null; then
 mise install node@lts
 mise use node@lts
else
    error "❌ mise not found. Please install mise or ensure Node.js LTS is available."
    exit 1
fi

info "📦 Installing Node.js dependencies..."
npm ci

info "🔨 Building OmniRoute CLI..."
npm run build:release

# --- Configuração do Serviço ---
ensure_env_file

# Read PORT from .env file for health check
OMNIROUTE_PORT=$(read_env_port "$OMNIROUTE_ENV_DIR/.env")
HEALTH_CHECK_URL="http://localhost:${OMNIROUTE_PORT}/api/monitoring/health"
info "🔍 Health check will target: $HEALTH_CHECK_URL"

info "📋 Refreshing systemd..."
systemctl --user daemon-reload
systemctl --user enable omniroute.service

info "🔄 Restarting OmniRoute service..."
systemctl --user restart omniroute.service

# --- Verificação ---
info "🏥 Performing health check..."
if health_check; then
    info "✅ OmniRoute installation/update completed successfully!"
    info "📊 Dashboard: http://localhost:${OMNIROUTE_PORT}"
    info "🔌 API Base: http://localhost:${OMNIROUTE_PORT}/v1  # Assuming API is PORT+1"
else
    error "OmniRoute installation/update failed. Check logs at $LOG_FILE"
    exit 1
fi

{{ end }}