#!/usr/bin/env bash
# Deploy Hermes cron jobs from chezmoi template
# This script is run on change of the cron jobs template

{{ template "common/script_helper" . -}}
{{ template "common/script_is_not_ephemeral" . -}}

# Source directory
TEMPLATE_FILE="{{ .chezmoi.sourceDir }}/home/private_dot_hermes/private_cron_jobs.json.tmpl"
TARGET_FILE="{{ .chezmoi.homeDir }}/.hermes/cron/jobs.json"

info "📋 Deploying Hermes cron jobs..."

# Check if template exists
if [[ ! -f "$TEMPLATE_FILE" ]]; then
    error "❌ Template file not found: $TEMPLATE_FILE"
    exit 1
fi

# Render template using chezmoi
mkdir -p "$(dirname "$TARGET_FILE")"
chezmoi execute-template "$TEMPLATE_FILE" > "$TARGET_FILE"

if [[ $? -eq 0 ]]; then
    success "✅ Cron jobs deployed to $TARGET_FILE"
    
    # Reload Hermes cron if running
    if command -v hermes &> /dev/null; then
        info "🔄 Reloading Hermes cron jobs..."
        hermes cron reload 2>&1 | tee -a /tmp/chezmoi/logs/hermes-cron-deploy.log || warn "⚠️  Could not reload cron (Hermes may not be running)"
    fi
else
    error "❌ Failed to deploy cron jobs"
    exit 1
fi