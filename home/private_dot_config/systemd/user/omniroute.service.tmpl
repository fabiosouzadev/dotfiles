[Unit]
Description=OmniRoute AI Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
{{- if eq .features.ai.omniroute.mode "vps-server" }}
Environment=HOST=0.0.0.0
{{- end }}
Environment=NODE_ENV=production
ExecStart={{ .chezmoi.homeDir }}/.local/bin/omniroute
Restart=on-failure
RestartSec=5
WorkingDirectory={{ .chezmoi.homeDir }}/.omniroute

[Install]
WantedBy=default.target
