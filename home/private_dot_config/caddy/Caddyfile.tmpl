{{- if and .settings.vps (ne .features.ai.omniroute.domain "") }}
# =====================================================================
# OMNIROUTE — Subdomínio dedicado (principal)
# Next.js serve na raiz /; subdomínio evita problema de base path.
# =====================================================================
omniroute.{{ .features.ai.omniroute.domain }} {
    handle {
        reverse_proxy 127.0.0.1:{{ .features.ai.omniroute.dashboard_port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    handle /_next* {
        reverse_proxy 127.0.0.1:{{ .features.ai.omniroute.dashboard_port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }
    handle /favicon.ico {
        reverse_proxy 127.0.0.1:{{ .features.ai.omniroute.dashboard_port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }
    handle /manifest.webmanifest {
        reverse_proxy 127.0.0.1:{{ .features.ai.omniroute.dashboard_port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }
    handle /icon-*.png {
        reverse_proxy 127.0.0.1:{{ .features.ai.omniroute.dashboard_port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }
    handle /apple-touch-icon.png {
        reverse_proxy 127.0.0.1:{{ .features.ai.omniroute.dashboard_port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    log {
        output file /var/log/caddy/omniroute-dashboard-access.log
        format console
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
{{- end }}

{{- if and .settings.vps (ne .features.ai.hermes.dashboard.domain "") }}
# =====================================================================
# HERMES DASHBOARD — Subdomínio dedicado
# =====================================================================
{{ .features.ai.hermes.dashboard.domain }} {
    handle {
        reverse_proxy 127.0.0.1:{{ .features.ai.hermes.dashboard.port }} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up Origin http://127.0.0.1:{{ .features.ai.hermes.dashboard.port }}
            header_up Referer http://127.0.0.1:{{ .features.ai.hermes.dashboard.port }}/
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    log {
        output file /var/log/caddy/hermes-dashboard-access.log
        format console
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
{{- end }}