[tools]
node           = "20"
"npm:npx"      = 'latest'
"npm:prettier" = 'latest'
java           = [ "latest", "21" ]
go             = "1.25.1"
python         = 'latest'
uv             = 'latest'


[settings]
experimental = true

# read version files used by other version managers, such as .nvmrc
idiomatic_version_file_enable_tools = ['java', 'node', 'python']
