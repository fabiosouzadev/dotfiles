{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "ollama/minimax-m2.7:cloud",
  "provider": {
    "ollama": {
      "models": {
        "minimax-m2.7:cloud": {
          "_launch": true,
          "limit": {
            "context": 204800,
            "output": 128000
          },
          "name": "minimax-m2.7:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "openrouter": {
      "models": {
        "minimax/minimax-m2.5:free": {},
        "openrouter/free": {}
      }
    }
  },
  "theme": "catppuccin"
}