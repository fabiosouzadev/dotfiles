[user]
	name       = Fabio Souza
	email      = fabiovanderlei.developer@gmail.com
	signingkey = 9D79F9FD64781516

[commit]
    gpgsign = true

[tag]
    gpgSign = true

[color]
	ui = true

[init]
    defaultBranch = main

[core]
	editor = nvim
	pager  = delta

[interactive]
	diffFilter = delta --color-only

[include]
	path = "~/.config/git/themes/catppuccin.gitconfig"

[delta]
	features = "catppuccin-mocha"
	line-numbers = true
	navigate = true
	side-by-side = true
	dark = true

[fetch]
	prune  = true
	rebase = true

{{/*
[merge]
	tool = "nvimdiff"
	conflictStyle = zdiff3
*/}}

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rebase]
	autoStash = true

[credential]
	helper = "gh auth git-credential"

[diff]
	colorMoved = "zebra"

[gpg]
	program = "{{ .gpg.program -}}"

{{/* Git > 2.36 hasconfig not working 
[includeIf "hasconfig:remote.*.url:ssh://git@gitdev.clarobrasil.mobi/*"]
    path = ~/.config/git/config.zup.inc
*/}}

[includeIf "gitdir:{{.dirs.workspaces.zup}}"]
    path = ~/.config/git/config.zup.inc