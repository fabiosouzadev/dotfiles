#!/usr/bin/env bash
# Hermes Configuration/State Sync Tool
# Sincroniza o estado essencial do Hermes via Chezmoi, criptografado com age.
# Modelo sustentável inspirado no omniroute-sync: arquivos pequenos + SQL seletivo + manifest.

set -euo pipefail

HERMES_DIR="${HERMES_HOME:-${HOME}/.hermes}"
SYNC_DIR="${HERMES_DIR}/sync"
MANIFEST_FILE="${SYNC_DIR}/manifest.json"
KANBAN_SQL_FILE="${SYNC_DIR}/kanban-config.sql"
SKILLS_MANIFEST_FILE="${SYNC_DIR}/skills-manifest.tsv"

# Arquivos pequenos/estáveis que definem identidade/configuração sensível do Hermes.
# Secrets e estado privado continuam criptografados via chezmoi.
# O config.yaml agora é mantido separadamente como template plaintext,
# referenciando segredos via variáveis de ambiente do .env.
ENCRYPTED_FILES=(
  .env
  auth.json
  gmail_app_password.txt
  memories/MEMORY.md
  memories/USER.md
  cron/jobs.json
  channel_directory.json
  gateway_state.json
  mcp_servers.json
  shell-hooks-allowlist.json
  sync/manifest.json
  sync/kanban-config.sql
  sync/skills-manifest.tsv
)

# Kanban: preservar só estado semântico, não runtime/execuções/notificações.
KANBAN_TABLES=(
  tasks
  task_links
  task_comments
)

FORBIDDEN_SOURCE_PATTERNS=(
  'private_dot_hermes/encrypted_private_backup.tar.gz.asc'
  'private_dot_hermes/private_backup.tar.gz'
  'private_dot_hermes/encrypted_state.db.asc'
  'private_dot_hermes/private_state.db'
  'private_dot_hermes/private_sessions'
  'private_dot_hermes/private_logs'
  'private_dot_hermes/private_cache'
)

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "❌ Comando obrigatório não encontrado: $1"
    exit 1
  fi
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))'
}

print_usage() {
  echo "Uso: hermes-sync {push|pull|status|doctor|export}"
  echo "  export : Gera manifest, kanban SQL seletivo e skills manifest"
  echo "  push   : Exporta e adiciona arquivos pequenos ao chezmoi criptografado"
  echo "  pull   : Restaura/importa estado seletivo depois de chezmoi apply"
  echo "  status : Verifica estado local e arquivos de sincronização"
  echo "  doctor : Valida se o chezmoi não contém blobs proibidos"
}

source_root() {
  chezmoi source-path 2>/dev/null | sed 's#/home$##'
}

export_manifest() {
  require_cmd python3
  mkdir -p "$SYNC_DIR"
  python3 - <<PY
import json, os, sqlite3, subprocess, time
from pathlib import Path
root = Path(os.path.expanduser(${HERMES_DIR@Q}))
sync = Path(os.path.expanduser(${SYNC_DIR@Q}))

def size(path):
    p=root/path
    if not p.exists(): return None
    if p.is_file(): return p.stat().st_size
    total=0; files=0
    for f in p.rglob('*'):
        if f.is_file():
            files += 1; total += f.stat().st_size
    return {'files': files, 'bytes': total}

def sqlite_counts(name):
    p=root/name
    if not p.exists(): return None
    out={'bytes': p.stat().st_size, 'tables': {}}
    con=sqlite3.connect(p)
    cur=con.cursor()
    for (t,) in cur.execute("select name from sqlite_master where type='table' order by name"):
        try:
            out['tables'][t]=cur.execute(f'select count(*) from "{t}"').fetchone()[0]
        except Exception:
            out['tables'][t]=None
    con.close()
    return out

try:
    hv=subprocess.run(['hermes','--version'], capture_output=True, text=True, timeout=10).stdout.strip().splitlines()
except Exception:
    hv=[]

manifest={
    'created_utc': time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()),
    'source_host': os.uname().nodename,
    'hermes_dir': str(root),
    'backup_model': 'chezmoi plaintext config template + encrypted secrets/small state + selective SQL; not full history backup',
    'hermes_version': hv,
    'included_files': [],
    'sizes': {k: size(Path(k)) for k in ['config.yaml','.env','auth.json','gmail_app_password.txt','memories','cron','plugins','skills','sessions','state.db','kanban.db']},
    'sqlite': {
        'kanban': sqlite_counts('kanban.db'),
        'state_summary': sqlite_counts('state.db'),
    },
    'excluded_by_design': [
        'state.db full message/session history',
        'sessions/', 'logs/', 'cache/', 'audio_cache/', 'hermes-agent/',
        'skills/ full tree; use skills-manifest.tsv and reinstall/version important local skills separately'
    ]
}
# Do not embed shell array weirdness; set included explicitly here.
manifest['included_files'] = [
  'config.yaml','.env','auth.json','gmail_app_password.txt','memories/MEMORY.md','memories/USER.md',
  'cron/jobs.json','channel_directory.json','gateway_state.json','mcp_servers.json','shell-hooks-allowlist.json',
  'sync/manifest.json','sync/kanban-config.sql','sync/skills-manifest.tsv'
]
(sync/'manifest.json').write_text(json.dumps(manifest, indent=2, ensure_ascii=False) + '\n')
PY
}

export_kanban_sql() {
  mkdir -p "$SYNC_DIR"
  : > "$KANBAN_SQL_FILE"
  if [ ! -f "$HERMES_DIR/kanban.db" ]; then
    echo "-- kanban.db missing at export time" > "$KANBAN_SQL_FILE"
    return
  fi

  python3 - <<PY
import os, sqlite3, time
from pathlib import Path

hermes_dir = Path(os.path.expanduser(${HERMES_DIR@Q}))
out = Path(os.path.expanduser(${KANBAN_SQL_FILE@Q}))
tables = ['tasks', 'task_links', 'task_comments']
delete_order = list(reversed(tables))

def q_ident(name: str) -> str:
    return '"' + name.replace('"', '""') + '"'

def q_value(value):
    if value is None:
        return 'NULL'
    if isinstance(value, bool):
        return '1' if value else '0'
    if isinstance(value, int):
        return str(value)
    if isinstance(value, float):
        return repr(value)
    if isinstance(value, bytes):
        return "X'" + value.hex() + "'"
    return "'" + str(value).replace("'", "''") + "'"

con = sqlite3.connect(hermes_dir / 'kanban.db')
cur = con.cursor()
existing = {row[0] for row in cur.execute("select name from sqlite_master where type='table'")}

lines = [
    '-- Hermes kanban semantic export',
    f"-- Exported at: {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}",
    '-- Generated by hermes-sync; intentionally excludes runs/events/attachments/notifications.',
    'PRAGMA foreign_keys=OFF;',
    'BEGIN TRANSACTION;',
]

for table in delete_order:
    if table in existing:
        lines.append(f'DELETE FROM {q_ident(table)};')

for table in tables:
    if table not in existing:
        continue
    rows = cur.execute(f'SELECT * FROM {q_ident(table)}').fetchall()
    cols = [desc[0] for desc in cur.description]
    col_sql = ', '.join(q_ident(c) for c in cols)
    for row in rows:
        values_sql = ', '.join(q_value(v) for v in row)
        lines.append(f'INSERT OR REPLACE INTO {q_ident(table)} ({col_sql}) VALUES ({values_sql});')

lines.append('COMMIT;')
out.write_text('\n'.join(lines) + '\n')
con.close()
PY
}

export_skills_manifest() {
  mkdir -p "$SYNC_DIR"
  {
    echo -e "category\tskill\tbytes\tfiles\tpath"
    if [ -d "$HERMES_DIR/skills" ]; then
      python3 - <<PY
from pathlib import Path
root=Path(${HERMES_DIR@Q})/'skills'
for skill_md in sorted(root.glob('**/SKILL.md')):
    d=skill_md.parent
    rel=d.relative_to(root)
    parts=rel.parts
    category='/'.join(parts[:-1]) if len(parts)>1 else ''
    skill=parts[-1]
    files=[p for p in d.rglob('*') if p.is_file()]
    size=sum(p.stat().st_size for p in files)
    print(f"{category}\t{skill}\t{size}\t{len(files)}\t{rel}")
PY
    fi
  } > "$SKILLS_MANIFEST_FILE"
}

run_export() {
  echo "📦 Exportando estado seletivo do Hermes..."
  export_kanban_sql
  export_skills_manifest
  export_manifest
  chmod 700 "$SYNC_DIR" 2>/dev/null || true
  chmod 600 "$SYNC_DIR"/* 2>/dev/null || true
  echo "✓ Gerado: $MANIFEST_FILE"
  echo "✓ Gerado: $KANBAN_SQL_FILE"
  echo "✓ Gerado: $SKILLS_MANIFEST_FILE"
}

add_existing_files() {
  require_cmd chezmoi
  echo "🔐 Adicionando arquivos pequenos ao Chezmoi com criptografia..."
  for rel in "${ENCRYPTED_FILES[@]}"; do
    path="$HERMES_DIR/$rel"
    if [ -f "$path" ]; then
      chezmoi add --encrypt "$path"
      echo "  + $rel"
    fi
  done
}

run_doctor() {
  require_cmd chezmoi
  local src
  src="$(source_root)"
  if [ -z "$src" ] || [ ! -d "$src" ]; then
    echo "⚠️  Não consegui localizar o source do chezmoi"
    return 1
  fi
  echo "🩺 Hermes sync doctor"
  echo "Chezmoi source: $src"
  local failed=0
  for pat in "${FORBIDDEN_SOURCE_PATTERNS[@]}"; do
    if [ -e "$src/home/$pat" ]; then
      echo "❌ Proibido encontrado: home/$pat"
      failed=1
    fi
  done
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    size=$(stat -c%s "$f" 2>/dev/null || echo 0)
    if [ "$size" -gt 1048576 ]; then
      case "$f" in
        *.asc) echo "ℹ️  Arquivo criptografado >1MB: ${f#$src/} ($size bytes) — verifique se é intencional" ;;
        *) echo "❌ Arquivo plaintext >1MB no chezmoi: ${f#$src/} ($size bytes)"; failed=1 ;;
      esac
    fi
  done < <(find "$src/home/private_dot_hermes" -type f 2>/dev/null || true)
  if [ "$failed" -eq 0 ]; then
    echo "✅ Nenhum blob proibido/plaintext perigoso encontrado"
  fi
  return "$failed"
}

case "${1:-}" in
  export)
    run_export
    ;;

  push)
    run_export
    add_existing_files
    run_doctor
    echo "✓ Pronto. Agora rode: chezmoi cd && git status && git add . && git commit -m \"backup: update Hermes sync\" && git push"
    ;;

  pull)
    require_cmd sqlite3
    echo "📥 Restaurando estado seletivo do Hermes..."
    echo "⚠️  Pressupõe que você já rodou 'chezmoi apply' para materializar os arquivos criptografados."
    if [ -f "$KANBAN_SQL_FILE" ] && [ -f "$HERMES_DIR/kanban.db" ]; then
      sqlite3 "$HERMES_DIR/kanban.db" < "$KANBAN_SQL_FILE"
      echo "✓ Kanban semântico importado de $KANBAN_SQL_FILE"
    else
      echo "ℹ️  Kanban import pulado (arquivo SQL ou kanban.db ausente)"
    fi
    echo "✓ Arquivos de configuração/secrets já são restaurados pelo chezmoi apply"
    echo "🔄 Próximos passos recomendados: hermes doctor && hermes gateway restart"
    ;;

  status)
    echo "🔍 Hermes Sync Status"
    echo "--------------------------"
    echo "Hermes dir: $HERMES_DIR"
    [ -d "$HERMES_DIR" ] && echo "✅ Hermes dir: Present" || echo "❌ Hermes dir: Missing"
    for rel in config.yaml .env auth.json gmail_app_password.txt memories/MEMORY.md memories/USER.md cron/jobs.json channel_directory.json gateway_state.json sync/manifest.json sync/kanban-config.sql sync/skills-manifest.tsv; do
      if [ -f "$HERMES_DIR/$rel" ]; then
        ls -lh "$HERMES_DIR/$rel" | awk -v r="$rel" '{print "✅ " r ": " $5}'
      else
        echo "⚠️  $rel: Missing"
      fi
    done
    if [ -f "$MANIFEST_FILE" ]; then
      echo "   Manifest timestamp: $(python3 - "$MANIFEST_FILE" <<'PY' 2>/dev/null || echo unknown
import json, sys
with open(sys.argv[1], encoding='utf-8') as fh:
    print(json.load(fh).get('created_utc', 'unknown'))
PY
)"
    fi
    ;;

  doctor)
    run_doctor
    ;;

  *)
    print_usage
    exit 1
    ;;
esac
