# ──────────────────────────────────────────────────────────────────────
#  OmniRoute — Docker Compose (Production Snapshot)
# ──────────────────────────────────────────────────────────────────────
#
#  Create a edge network
#
#  Usage:
#    docker network create edge
#
#  networks:
#   edge:
#     external: true
#
# ──────────────────────────────────────────────────────────────────────
services:
  caddy:
    image: caddy:alpine
    restart: unless-stopped
    cap_add:
      - NET_ADMIN
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp" # HTTP/3 support
      - "20128:20128"
      - "20129:20129"
      - "20132:20132"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - edge
volumes:
  caddy_data:
  caddy_config:
networks:
  edge:
    external: true