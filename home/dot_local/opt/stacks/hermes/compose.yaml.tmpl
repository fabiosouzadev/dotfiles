services:
  hermes:
    image: nousresearch/hermes-agent:latest
    container_name: hermes
    restart: unless-stopped
    command: gateway run
    ports:
      - 8642:8642 # gateway API
    volumes:
      - ./data:/opt/data
    environment:
      - OMNIROUTE_BASE_URL=omniroute/v1
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: "2.0"
networks:
  edge:
    external: true
