services:
  hermes:
    image: nousresearch/hermes-agent:latest
    container_name: hermes
    restart: unless-stopped
    command: gateway run
    ports:
      - "8642:8642"     # gateway API
      - "9119:9119"     # dashboard (only reached when HERMES_DASHBOARD=1)
    volumes:
      - {{ .chezmoi.homeDir }}/.hermes:/opt/data
    environment:
      PUID: "${PUID:-1000}"
      PGID: "${PGID:-1000}"
      HERMES_DASHBOARD: "1"
      OMNIROUTE_BASE_URL: "http://omniroute:20129/v1"
    shm_size: "1g"  
    networks:
      - edge
networks:
  edge:
    external: true