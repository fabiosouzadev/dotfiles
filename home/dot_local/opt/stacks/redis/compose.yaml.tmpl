services:
  redis:
    image: redis:8.6.2-alpine
    container_name: redis
    restart: unless-stopped
    volumes:
      - redis-prod-data:/data
    command: redis-server --save 60 1 --loglevel warning
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3
volumes:
  redis-prod-data:
    name: redis-prod-data
