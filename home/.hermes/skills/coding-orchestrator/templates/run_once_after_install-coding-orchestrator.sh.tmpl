#!/usr/bin/env bash
# run_once_after_XXX-install-coding-orchestrator.sh.tmpl
# Instala e configura a skill coding-orchestrator no VPS
# Executado automaticamente pelo chezmoi apply

set -euo pipefail

info() { echo -e "\033[1;34m[INFO]\033[0m $*"; }
success() { echo -e "\033[1;32m[SUCCESS]\033[0m $*"; }
warn() { echo -e "\033[1;33m[WARN]\033[0m $*" >&2; }
error() { echo -e "\033[1;31m[ERROR]\033[0m $*" >&2; exit 1; }

info ">>>>>> 🤖 Installing Coding Orchestrator Skill 🤖 <<<<<<"

# 1. Verifica se skill já existe
SKILL_DIR="$HOME/.hermes/skills/coding-orchestrator"
if [[ -d "$SKILL_DIR" ]]; then
    info "Skill coding-orchestrator já existe em $SKILL_DIR"
else
    info "Skill será criada pelo chezmoi (arquivos em home/.hermes/skills/coding-orchestrator/)"
fi

# 2. Cria diretório de worktrees
WORKTREE_BASE="$HOME/worktrees"
if [[ ! -d "$WORKTREE_BASE" ]]; then
    info "Criando diretório de worktrees: $WORKTREE_BASE"
    mkdir -p "$WORKTREE_BASE"
    success "Worktree base criada"
else
    info "Diretório worktrees já existe: $WORKTREE_BASE"
fi

# 3. Cria diretório de logs
LOG_DIR="$HOME/.hermes/logs/coding-orchestrator"
if [[ ! -d "$LOG_DIR" ]]; then
    info "Criando diretório de logs: $LOG_DIR"
    mkdir -p "$LOG_DIR"
    success "Log directory criado"
else
    info "Log directory já existe: $LOG_DIR"
fi

# 4. Verifica dependências
info "Verificando dependências..."

# git
if ! command -v git >/dev/null 2>&1; then
    error "git não encontrado. Instale com: sudo apt-get install git"
fi
success "git: $(git --version)"

# gh CLI (opcional)
if command -v gh >/dev/null 2>&1; then
    success "gh CLI: $(gh --version | head -1)"
else
    warn "gh CLI não encontrado (opcional, para GitHub integration). Instale: https://cli.github.com/"
fi

# mise
if ! command -v mise >/dev/null 2>&1; then
    error "mise não encontrado. Necessário para Node.js agents"
fi
success "mise: $(mise --version)"

# Node.js via mise
if mise exec node@20 -- node --version >/dev/null 2>&1; then
    NODE_VER=$(mise exec node@20 -- node --version)
    success "Node.js 20 via mise: $NODE_VER"
else
    warn "Node.js 20 não instalado via mise. Execute: mise install node@20"
fi

# Aider
if command -v aider >/dev/null 2>&1; then
    success "Aider: $(aider --version)"
else
    warn "Aider não encontrado. Instale com: pip3 install aider-chat"
fi

# 5. Verifica OmniRoute
info "Verificando OmniRoute..."
if systemctl --user is-active --quiet omniroute; then
    success "OmniRoute service ativo"
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:20128/api/monitoring/health | grep -q 200; then
        success "OmniRoute health check OK (porta 20128)"
    else
        warn "OmniRoute health check falhou"
    fi
else
    warn "OmniRoute service NÃO ativo. Execute: systemctl --user start omniroute"
fi

# 6. Torna scripts executáveis
info "Configurando permissões dos scripts..."
SCRIPTS=(
    "coding-orchestrator.sh"
    "gather-context.sh"
    "create-worktree.sh"
    "run-agent.sh"
    "deliver-results.sh"
)
for script in "${SCRIPTS[@]}"; do
    SCRIPT_PATH="$SKILL_DIR/scripts/$script"
    if [[ -f "$SCRIPT_PATH" ]]; then
        chmod +x "$SCRIPT_PATH"
        success "Script executável: $script"
    else
        warn "Script não encontrado: $script (será copiado pelo chezmoi)"
    fi
done

# 7. Recarrega skills do Hermes
info "Recarregando skills do Hermes..."
if command -v hermes >/dev/null 2>&1; then
    hermes skill reload 2>/dev/null || warn "Falha ao recarregar skills (Hermes pode não estar rodando)"
    success "Skills recarregadas"
else
    warn "Hermes CLI não encontrado no PATH"
fi

# 8. Verifica se skill foi carregada
if hermes skills list 2>/dev/null | grep -q "coding-orchestrator"; then
    success "Skill coding-orchestrator carregada com sucesso!"
else
    warn "Skill não aparece na lista. Verifique: hermes skills list"
fi

# 9. Configura cron job se habilitado no chezmoi
{{ if .features.ai.coding_orchestrator.cron.enabled }}
info "Configurando cron job noturno..."
CRON_JOB_ID="coding-orchestrator-nightly"
# O job será criado via Hermes cron API ou manualmente
warn "Cron job deve ser configurado via: hermes cron create ..."
{{ else }}
info "Cron job desabilitado na configuração (features.ai.coding_orchestrator.cron.enabled: false)"
{{ end }}

success ">>>>>> 🤖 Coding Orchestrator instalado com sucesso! 🤖 <<<<<<"

info "Próximos passos:"
info "  1. Configure triggers (Telegram, Webhook, GitHub label) conforme references/trigger-implementation.md"
info "  2. Ajuste config.yaml se necessário: ~/.hermes/skills/coding-orchestrator/config.yaml"
info "  3. Teste manual: ~/.hermes/skills/coding-orchestrator/scripts/coding-orchestrator.sh manual \"test task\""
info "  4. Verifique logs em: ~/.hermes/logs/coding-orchestrator/"