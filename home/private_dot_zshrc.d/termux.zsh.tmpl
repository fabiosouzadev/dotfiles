{{- if .settings.termux -}}
## ═══════════════════════════════════════════════════════════════════════════════
## Termux (Android) — Configuração mínima
## ═══════════════════════════════════════════════════════════════════════════════

# Caminhos Termux
export PREFIX="/data/data/com.termux/files/usr"
export HOME="/data/data/com.termux/files/home"
export PATH="$HOME/.local/bin:$PREFIX/bin:$PATH"

# Editor
export EDITOR="nano"
export VISUAL="nano"

# ── Aliases essenciais ──────────────────────────────────────────────────────
alias ll="ls -lah"
alias la="ls -A"
alias l="ls -CF"
alias ..="cd .."
alias ...="cd ../.."

# Git
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git log --oneline -10"
alias gd="git diff"

# VPS
alias vps="ssh vps"
alias vps-update="ssh vps -- chezmoi apply"
alias vps-logs="ssh vps -- journalctl -u omniroute -f"

# System
alias df="df -h"
alias du="du -h"
alias free="free -h"
alias top="htop"

# ──Prompt simples (sem starship no Termux) ─────────────────────────────────
PS1='%F{green}%n@%m%f:%F{blue}%~%f$ '

# ── Zinit plugins (leves para móvil) ───────────────────────────────────────
if [[ -d "${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git" ]]; then
  source "${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git/zinit.zsh"
  autoload -Uz _zinit
  (( ${+_comps} )) && _comps[zinit]=_zinit

  zinit wait lucid for \
    atinit"ZINIT[COMPINIT_FLAGS]=-C; zicompinit; zicdreplay" \
      zdharma-continuum/fast-syntax-highlighting \
    zsh-users/zsh-autosuggestions
fi

# ── Termux API ──────────────────────────────────────────────────────────────
if command -v termux-info &>/dev/null; then
  # Atalhos úteis
  alias battery="termux-battery-status"
  alias clipboard-get="termux-clipboard-get"
  alias clipboard-set="termux-clipboard-set"
  alias wifi-info="termux-wifi-connectioninfo"
  alias torch-on="termux-torch on"
  alias torch-off="termux-torch off"
  alias vibrate="termux-vibrate -d 200"
  alias sms-list="termux-sms-list -l 5"
  alias location="termux-location"
  alias notification="termux-notification"
  alias toast="termux-toast"
  alias volume="termux-volume"
  alias brightness="termux-brightness"

  # Abrir URL no navegador
  open() {
    termux-open-url "$@" 2>/dev/null || xdg-open "$@" 2>/dev/null || echo "Não foi possível abrir: $@"
  }

  # Copiar para clipboard
  copy() {
    if [[ -t 0 ]]; then
      # Argumento direto
      echo "$*" | termux-clipboard-set
      echo "✓ Copiado para clipboard"
    else
      # Pipe
      termux-clipboard-set
      echo "✓ Copiado para clipboard"
    fi
  }

  # Colar do clipboard
  paste() {
    termux-clipboard-get
  }

  # Compartilhar arquivo
  share() {
    if [[ -f "$1" ]]; then
      termux-share "$1"
    else
      echo "Arquivo não encontrado: $1"
    fi
  }

  # Backup do Termux para a VPS
  termux-backup() {
    echo "==> Fazendo backup do Termux..."
    local backup_dir="/sdcard/Download/termux-backup-$(date +%Y%m%d)"
    mkdir -p "$backup_dir"
    cp -r "$HOME/.ssh" "$backup_dir/" 2>/dev/null || true
    cp -r "$HOME/.local" "$backup_dir/" 2>/dev/null || true
    cp "$HOME/.zshrc" "$backup_dir/" 2>/dev/null || true
    cp -r "$HOME/.config" "$backup_dir/" 2>/dev/null || true

    # Copiar para VPS via rsync (requer SSH key configurada)
    rsync -avz --progress "$backup_dir/" "vps:~/backups/termux/" 2>&1 || \
      echo "⚠️  rsync falhou. Backup local: $backup_dir"
  }
fi

# ── Utilidades SSH/VPS ──────────────────────────────────────────────────────
# Gerar QR code de conexão (para compartilhar acesso)
qr-ssh() {
  local vps_ip="{{ .features.ai.omniroute.domain | default "fabiosouzadev.duckdns.org" }}"
  local qr_text="ssh ubuntu@${vps_ip}"
  if command -v qrencode &>/dev/null; then
    qrencode -t ANSIUTF8 "$qr_text"
  else
    echo "Instale qrencode: pkg install qrencode"
    echo "Ou use: $qr_text"
  fi
}

# Status rápido da VPS
vps-status() {
  ssh vps -- curl -sf http://localhost:20128/health 2>/dev/null && \
    echo "✅ OmniRoute OK" || echo "❌ OmniRoute offline"
}

# Sincronizar dotfiles da VPS
termux-sync() {
  echo "==> Sincronizando dotfiles da VPS..."
  ssh vps -- "cd ~/.local/share/chezmoi && git pull" 2>&1
  echo "✓ Dotfiles atualizados na VPS"
}

# ── FZF (se instalado) ─────────────────────────────────────────────────────
if command -v fzf &>/dev/null; then
  source <(fzf --zsh 2>/dev/null) || true
fi

# ── Histórico ───────────────────────────────────────────────────────────────
HISTFILE="$HOME/.zsh_history"
HISTSIZE=5000
SAVEHIST=5000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS

# ── Autocomplete básico ────────────────────────────────────────────────────
autoload -Uz compinit
compinit -C

# vim: filetype=bash
{{- end -}}
