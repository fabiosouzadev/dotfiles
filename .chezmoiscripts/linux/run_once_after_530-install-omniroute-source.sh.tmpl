#!/usr/bin/env bash
# Instala / atualiza o OmniRoute from source
# Uso:
#   run_once_after_530-install-omniroute-source.sh [versão]
#   versão = "main" (padrão, mais recente) ou "v3.8.34" (tag específica)
set -euo pipefail

SRC_DIR="{{ .chezmoi.homeDir }}/.local/src/OmniRoute"
BIN_SRC="$SRC_DIR/bin/omniroute"
BIN_LINK="{{ .chezmoi.homeDir }}/.local/bin/omniroute"
VERSION="{{ .omniroute.install.version }}"

# Permite sobrescrever via argumento: chezmoi apply -v v3.8.34
if [[ "${1:-}" =~ ^v?[0-9] ]]; then
  VERSION="$1"
fi

echo "==> OmniRoute — instalando from source (versão: $VERSION)"

# Garante que ~/.local/bin existe
mkdir -p "$(dirname "$BIN_LINK")"

# Clona ou atualiza o repo
if [[ -d "$SRC_DIR/.git" ]]; then
  echo "  → Repo já existe, atualizando..."
  cd "$SRC_DIR"
  git fetch --all --tags --prune 2>&1 | sed 's/^/    /'
else
  echo "  → Clonando {{ .omniroute.install.repo }}..."
  git clone "{{ .omniroute.install.repo }}" "$SRC_DIR" 2>&1 | sed 's/^/    /'
  cd "$SRC_DIR"
fi

# Checkout da versão desejada
if [[ "$VERSION" == "main" || "$VERSION" == "master" ]]; then
  git checkout main 2>&1 | sed 's/^/    /'
  git pull origin main 2>&1 | sed 's/^/    /'
else
  git checkout "$VERSION" 2>&1 | sed 's/^/    /'
fi

# Instala dependências e build
echo "  → Instalando dependências..."
npm ci 2>&1 | sed 's/^/    /'

echo "  → Buildando..."
npm run build 2>&1 | sed 's/^/    /'

# Symlink do binário
if [[ -f "$BIN_SRC" ]]; then
  ln -sf "$BIN_SRC" "$BIN_LINK"
  echo "  → Symlink criado: $BIN_LINK → $BIN_SRC"
else
  echo "  ✗ ERRO: binário não encontrado em $BIN_SRC"
  echo "    Verifique se o build gerou o binário corretamente."
  exit 1
fi

# Verificação
INSTALLED_VER=$("$BIN_LINK" --version 2>/dev/null || echo "desconhecida")
echo "✓ OmniRoute instalado com sucesso (versão: $INSTALLED_VER)"
