#!/usr/bin/env bash

{{- if eq .chezmoi.os "linux" }} 
    set -euo pipefail

    # Pretty print functions
    info()    { echo -e "\033[1;34m[INFO]\033[0m $*"; }
    warn()    { echo -e "\033[1;33m[WARN]\033[0m $*"; }
    error()   { echo -e "\033[1;31m[ERROR]\033[0m $*"; }
    success() { echo -e "\033[1;32m✅ $*\033[0m"; }

    info "Installing WM packages"

    {{ if (or (eq .chezmoi.osRelease.id "endeavouros") (eq .chezmoi.osRelease.id "cachyos")) }}

        {{ range .packages.linux.wm }}
            {{- $wmName := .name }}
            {{- $wmFlavors := .flavors }}
            info "Processing WM: {{ $wmName }}"

            {{- if $wmFlavors }}
                {{- if $wmFlavors.arch }}
                    {{- $archPackages := index $wmFlavors.arch "packages" }}
                    {{- if and $archPackages (gt (len $archPackages) 0) }}
                        info "Installing Arch {{ $wmName }} packages:"
                        sudo pacman -Syu --noconfirm --needed {{ range $archPackages }}{{.}} {{ end }}
                    {{- end }}

                    {{- $aurPackages := index $wmFlavors.arch "aur-packages" }}
                    {{- if and $aurPackages (gt (len $aurPackages) 0) }}
                        info "Installing AUR packages:"
                        if command -v "paru" > /dev/null; then
                            paru -Syu --noconfirm --needed {{ range $aurPackages}} {{.}}{{ end }}
                        elif type -P yay >/dev/null 2>&1; then
                            yay -Syu --noconfirm --needed {{ range $aurPackages}} {{.}}{{ end }}
                        fi
                    {{- end }}
                {{- else }}
                    warn "No arch flavor defined for '{{ $wmName }}'"
                {{- end }}
            {{- else }}
                warn "No flavors defined for '{{ $wmName }}'"
            {{- end }}
        {{ end }}
    {{ end }}

    {{ if (eq .chezmoi.osRelease.id "ubuntu") }}

        {{ range .packages.linux.wm }}
            {{- $wmName := .name }}
            {{- $wmFlavors := .flavors }}
            info "Processing WM: {{ $wmName }}"

            {{- if $wmFlavors }}
                {{- if $wmFlavors.ubuntu }}
                    {{- $ubuntuPackages := index $wmFlavors.ubuntu "packages" }}
                    {{- if and $ubuntuPackages (gt (len $ubuntuPackages) 0) }}
                        info "Installing Ubuntu {{ $wmName }} packages:"
                        sudo apt-get update -qq
                        sudo apt-get install -y --no-install-recommends {{ range $ubuntuPackages }}{{.}} {{ end }}
                    {{- else }}
                        info "No Ubuntu packages defined for '{{ $wmName }}'"
                    {{- end }}
                {{- else }}
                    warn "No ubuntu flavor defined for '{{ $wmName }}'"
                {{- end }}
            {{- else }}
                warn "No flavors defined for '{{ $wmName }}'"
            {{- end }}
        {{ end }}

    {{ end }}

{{ end }}
# vim: filetype=bash
